{
  "name": "neurocache",
  "private": true,
  "version": "0.1.0",
  "description": "AI-aware, Redis-compatible in-memory data store — monorepo root",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
